---
import BaseLayout from "./BaseLayout.astro";
import "../styles/prose.css";
import Tag from "../components/Tag.astro";
import { calculateReadingTime } from "../utils/readingTime";

const { frontmatter, rawContent } = Astro.props;

const contentString = typeof rawContent === "function" ? rawContent() : (rawContent || "");
const readingTime = contentString ? calculateReadingTime(contentString) : 0;

const formattedDate = new Date(frontmatter.date).toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
>
  <div class="back-link">
    <a href="/blog">← Back to Writing</a>
  </div>

  <article>
    <header class="post-header">
      <h1>{frontmatter.title}</h1>
      
      <div class="post-metadata">
        <time datetime={new Date(frontmatter.date).toISOString()}>{formattedDate}</time>
        {readingTime > 0 && (
          <>
            <span class="separator">·</span>
            <span>{readingTime} min read</span>
          </>
        )}
      </div>

      {frontmatter.tags && frontmatter.tags.length > 0 && (
        <div class="tags">
          {frontmatter.tags.map((tag) => (
            <Tag tag={tag} />
          ))}
        </div>
      )}
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
.back-link {
  margin-bottom: 2.5rem;
  font-family: "IBM Plex Mono", monospace;
  font-size: 0.85rem;
}

.back-link a {
  color: var(--muted);
}

.back-link a:hover {
  color: var(--text);
}

.post-header {
  margin-bottom: 3rem;
}

.post-header h1 {
  font-size: 2.25rem;
  line-height: 1.2;
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-top: 0;
  margin-bottom: 1rem;
  color: var(--text);
}

.post-metadata {
  font-family: "IBM Plex Mono", monospace;
  color: var(--muted);
  font-size: 0.85rem;
  margin-bottom: 1.5rem;
}

.post-metadata .separator {
  margin: 0 0.5rem;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
</style>