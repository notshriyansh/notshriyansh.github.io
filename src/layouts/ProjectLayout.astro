---
import BaseLayout from "./BaseLayout.astro";
import "../styles/prose.css";
import Tag from "../components/Tag.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
>
  <div class="back-link">
    <a href="/projects">← Back to Projects</a>
  </div>

  <article>
    <header class="project-header">
      <div class="title-row">
        <h1>{frontmatter.title}</h1>
        <span class="status-badge">{frontmatter.status}</span>
      </div>

      <p class="project-description">{frontmatter.description}</p>

      <div class="project-meta-row">
        {frontmatter.tags && frontmatter.tags.length > 0 && (
          <div class="tags">
            {frontmatter.tags.map((tag) => (
              <Tag tag={tag} />
            ))}
          </div>
        )}

        {frontmatter.github && (
          <a
            href={frontmatter.github}
            target="_blank"
            rel="noopener noreferrer"
            class="repo-link"
          >
            Repository →
          </a>
        )}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
.back-link {
  margin-bottom: 2.5rem;
  font-family: "IBM Plex Mono", monospace;
  font-size: 0.85rem;
}

.back-link a {
  color: var(--muted);
}

.back-link a:hover {
  color: var(--text);
}

.project-header {
  margin-bottom: 3rem;
  border-bottom: 1px solid var(--border);
  padding-bottom: 2rem;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 1rem;
  margin-bottom: 1rem;
}

.title-row h1 {
  font-size: 2.25rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  margin: 0;
  color: var(--text);
}

.status-badge {
  font-family: "IBM Plex Mono", monospace;
  font-size: 0.75rem;
  color: var(--accent);
  border: 1px solid var(--accent);
  padding: 0.15rem 0.5rem;
  border-radius: 4px;
  white-space: nowrap;
}

.project-description {
  font-size: 1.1rem;
  color: var(--muted);
  line-height: 1.5;
  margin-top: 0;
  margin-bottom: 1.5rem;
}

.project-meta-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 1rem;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.repo-link {
  font-family: "IBM Plex Mono", monospace;
  font-size: 0.85rem;
  color: var(--text);
  border: 1px solid var(--border);
  padding: 0.25rem 0.75rem;
  border-radius: 4px;
  transition: all 0.15s ease;
}

.repo-link:hover {
  border-color: var(--text);
  background-color: var(--surface);
}

@media (max-width: 500px) {
  .title-row {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.5rem;
  }
  
  .project-meta-row {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }
  
  .repo-link {
    width: 100%;
    text-align: center;
  }
}
</style>