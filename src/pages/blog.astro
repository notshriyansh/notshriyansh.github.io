---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogListItem from "../components/BlogListItem.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

const publishedPosts = posts
  .filter((post) => !post.data.draft)
  .sort(
    (a, b) =>
      b.data.date.getTime() -
      a.data.date.getTime()
  );
---

<BaseLayout title="Writing">
  <header class="page-header">
    <h1>Writing</h1>
    <p class="subtitle">
      Technical write-ups, analysis of research papers, and lessons learned from building software architectures.
    </p>
  </header>

  <div class="posts">
    {
      publishedPosts.length > 0 ? (
        publishedPosts.map((post) => (
          <BlogListItem post={post} />
        ))
      ) : (
        <p class="empty-state">No articles published yet.</p>
      )
    }
  </div>
</BaseLayout>

<style>
.page-header {
  margin-bottom: 2.5rem;
}

.page-header h1 {
  font-size: 1.75rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  margin-bottom: 0.75rem;
  color: var(--text);
}

.subtitle {
  color: var(--muted);
  font-size: 1rem;
  line-height: 1.6;
  margin: 0;
  max-width: 600px;
}

.posts {
  display: flex;
  flex-direction: column;
}

.empty-state {
  color: var(--muted);
  font-family: "IBM Plex Mono", monospace;
  font-size: 0.9rem;
}
</style>