---
const pathname = Astro.url.pathname;
const cleanPath = pathname.replace(/^\/|\/$/g, "");

const isActive = (route: string) => {
  if (route === "") {
    return cleanPath === "";
  }
  return cleanPath === route || cleanPath.startsWith(route + "/");
};
---

<header class="header">
  <a href="/" class="logo" aria-label="Shriyansh Sharma Home">
    Shriyansh Sharma
  </a>
  <nav class="nav" aria-label="Main Navigation">
    <a href="/blog" class={isActive("blog") ? "active" : ""} aria-current={isActive("blog") ? "page" : undefined}>
      Writing
    </a>
    <a href="/projects" class={isActive("projects") ? "active" : ""} aria-current={isActive("projects") ? "page" : undefined}>
      Projects
    </a>
    <a href="/about" class={isActive("about") ? "active" : ""} aria-current={isActive("about") ? "page" : undefined}>
      About
    </a>
    <a href="/now" class={isActive("now") ? "active" : ""} aria-current={isActive("now") ? "page" : undefined}>
      Now
    </a>
  </nav>
</header>

<style>
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.5rem 0 2rem 0;
  margin-bottom: 4rem;
  border-bottom: 1px solid var(--border);
}

.logo {
  font-weight: 600;
  font-size: 0.95rem;
  color: var(--text);
  letter-spacing: -0.01em;
}

.logo:hover {
  color: var(--accent);
}

.nav {
  display: flex;
  gap: 1.5rem;
  font-family: "IBM Plex Mono", monospace;
  font-size: 0.85rem;
}

.nav a {
  color: var(--muted);
  transition: color 0.15s ease;
}

.nav a:hover,
.nav a.active {
  color: var(--text);
}

@media (max-width: 500px) {
  .header {
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    padding: 1rem 0 1.5rem 0;
    margin-bottom: 2.5rem;
  }
  
  .nav {
    gap: 1.25rem;
  }
}
</style>