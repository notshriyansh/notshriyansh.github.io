---
const { tag } = Astro.props;
---

<span class="tag">
  #{tag}
</span>

<style>
.tag {
  display: inline-block;
  padding: 0.15rem 0.4rem;
  border: 1px solid var(--border);
  border-radius: 4px;
  color: var(--muted);
  font-family: "IBM Plex Mono", monospace;
  font-size: 0.75rem;
  line-height: 1.2;
  background-color: rgba(22, 26, 34, 0.2);
}
</style>