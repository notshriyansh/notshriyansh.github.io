---
import Tag from "./Tag.astro";
const { project } = Astro.props;
---

<div class="project-card">
  <div class="project-header">
    <h3>
      <a href={`/projects/${project.id}`} class="project-title-link">
        {project.data.title}
      </a>
    </h3>
    <span class="project-status">{project.data.status}</span>
  </div>

  <p class="project-description">
    {project.data.description}
  </p>

  <div class="project-footer">
    {project.data.tags && project.data.tags.length > 0 && (
      <div class="project-tags">
        {project.data.tags.map((tag) => (
          <Tag tag={tag} />
        ))}
      </div>
    )}

    {project.data.github && (
      <a
        href={project.data.github}
        target="_blank"
        rel="noopener noreferrer"
        class="repo-link"
        aria-label={`View code for ${project.data.title} on GitHub`}
      >
        Repository →
      </a>
    )}
  </div>
</div>

<style>
.project-card {
  padding: 1.5rem 0;
  border-bottom: 1px solid var(--border);
}

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
}

.project-header h3 {
  margin: 0;
  font-size: 1.15rem;
  font-weight: 600;
}

.project-title-link {
  color: var(--text);
  transition: color 0.15s ease;
}

.project-title-link:hover {
  color: var(--accent);
}

.project-status {
  font-family: "IBM Plex Mono", monospace;
  font-size: 0.75rem;
  color: var(--muted);
}

.project-description {
  margin: 0.5rem 0 1rem 0;
  color: var(--muted);
  font-size: 0.9rem;
  line-height: 1.5;
}

.project-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: 0.75rem;
}

.project-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.repo-link {
  font-family: "IBM Plex Mono", monospace;
  font-size: 0.8rem;
  color: var(--muted);
  transition: color 0.15s ease;
}

.repo-link:hover {
  color: var(--text);
}

@media (max-width: 500px) {
  .project-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
  }
  
  .project-footer {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
  }
  
  .repo-link {
    width: 100%;
  }
}
</style>